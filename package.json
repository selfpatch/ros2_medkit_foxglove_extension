{
  "name": "ros2-medkit-foxglove-extension",
  "displayName": "ros2_medkit Diagnostics",
  "description": "Foxglove Studio panels for browsing entities and monitoring faults via the ros2_medkit gateway HTTP API.",
  "publisher": "selfpatch",
  "homepage": "https://github.com/selfpatch/ros2_medkit_foxglove_extension",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "main": "./dist/extension.js",
  "keywords": [
    "medkit",
    "ros2",
    "diagnostics",
    "foxglove",
    "ros2_medkit"
  ],
  "scripts": {
    "build": "foxglove-extension build",
    "build:prod": "foxglove-extension build --mode production",
    "local-install": "foxglove-extension install",
    "package": "foxglove-extension package",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "foxglove:prepublish": "foxglove-extension build --mode production"
  },
  "devDependencies": {
    "@foxglove/extension": "^2.45.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "create-foxglove-extension": "^1.1.2",
    "jsdom": "^29.0.2",
    "react": "^18",
    "react-dom": "^18",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
